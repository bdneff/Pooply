rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users — only the authenticated user can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Logs subcollection — only the owning user
      match /logs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Invite codes — any authenticated user can read; updates limited to usage fields only
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentUses', 'redeemedBy']);
      // No create/delete from client
      allow create, delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
