# macOS
.DS_Store
**/.DS_Store

# Xcode — per-user state (don't commit, these change every time you open the project)
xcuserdata/
*.xcuserstate
*.xcuserdatad/

# Xcode — build artifacts
build/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.swiftpm/
.build/
Packages/
Package.pins
Package.resolved
*.xcodeproj/xcshareddata/swiftpm/

# CocoaPods (if ever used)
Pods/
Podfile.lock

# Carthage (if ever used)
Carthage/Build/
Carthage/Checkouts/

# fastlane (if ever used)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# Local secrets — never commit
*.env
.env.local
GoogleService-Info-Dev.plist

# Logs
*.log
